---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import NavArrow from '../../components/NavArrow.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, description, date } = post.data;
const { Content } = await render(post);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' });

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString().slice(0, 10),
  url: new URL(`/blog/${post.id}/`, Astro.site).href,
  author: {
    '@type': 'Person',
    name: 'Samip Pokharel',
    url: 'https://s4mip.dev',
  },
};
---

<Base title={`${title} · Samip Pokharel`} description={description} schema={schema}>
  <article class="py-12 sm:py-16">
    <a href="/blog/" class="text-sm text-neutral-500 transition-colors hover:text-neutral-900">
      <NavArrow direction="left" />All posts
    </a>

    <header class="mt-10">
      <p class="font-mono text-xs text-neutral-400">
        <time datetime={date.toISOString().slice(0, 10)}>{formatDate(date)}</time>
      </p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-neutral-900 sm:text-4xl">{title}</h1>
    </header>

    <div class="prose-body mt-10 max-w-prose">
      <Content />
    </div>
  </article>
</Base>
