---
import { getCollection } from 'astro:content';
import PenLineIcon from '../assets/icons/pen-line.svg';
import NavArrow from './NavArrow.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' });
---

<section id="writing" class="scroll-mt-8 border-t border-neutral-200 py-16" aria-labelledby="writing-heading">
  <h2 id="writing-heading" class="section-label flex items-center gap-2">
    <PenLineIcon width={14} height={14} aria-hidden="true" />
    Writing
  </h2>
  <ul class="mt-10 space-y-6">
    {
      posts.map((post) => (
        <li>
          <article class="grid gap-1 sm:grid-cols-[8rem_1fr] sm:gap-6">
            <p class="font-mono text-xs leading-6 text-neutral-400">
              <time datetime={post.data.date.toISOString().slice(0, 10)}>
                {formatDate(post.data.date)}
              </time>
            </p>
            <h3 class="font-medium">
              <a href={`/blog/${post.id}/`} class="link-quiet">
                {post.data.title}<NavArrow />
              </a>
            </h3>
          </article>
        </li>
      ))
    }
  </ul>
  <p class="mt-8 text-sm">
    <a href="/blog/" class="link-quiet font-medium">All posts<NavArrow /></a>
  </p>
</section>
