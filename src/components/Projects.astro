---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Tech from './Tech.astro';
import ExternalArrow from './ExternalArrow.astro';
import NavArrow from './NavArrow.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="projects" class="scroll-mt-8 border-t border-neutral-200 py-16" aria-labelledby="projects-heading">
  <h2 id="projects-heading" class="section-label">Projects</h2>

  <div class="mt-10 space-y-16">
    {
      projects.map((project, i) => (
        <article class="grid gap-6 md:grid-cols-[1fr_20rem] md:gap-10 lg:grid-cols-[1fr_26rem]">
          <div>
            <div class="flex items-baseline gap-4">
              <span class="font-mono text-xs text-neutral-400" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="text-xl font-medium">
                <a href={`/projects/${project.id}/`} class="text-neutral-900 transition-colors hover:text-(--color-accent)">
                  {project.data.title}
                </a>
              </h3>
            </div>

            <p class="mt-3 leading-relaxed">{project.data.description}</p>

            <ul class="mt-4 space-y-1.5 text-sm text-neutral-600">
              {project.data.highlights.map((point) => (
                <li class="flex gap-3">
                  <span class="text-neutral-400" aria-hidden="true">·</span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>

            <ul class="mt-5 flex flex-wrap gap-x-6 gap-y-3 text-xs text-neutral-500">
              {project.data.stack.map((tech) => (
                <li>
                  <Tech name={tech} size={14} />
                </li>
              ))}
            </ul>

            <p class="mt-4 flex gap-5 text-sm">
              <a href={`/projects/${project.id}/`} class="link-quiet font-medium">
                View case study<NavArrow />
                <span class="sr-only"> for {project.data.title}</span>
              </a>
              {project.data.github && (
                <a href={project.data.github} class="link-quiet">
                  GitHub<ExternalArrow />
                  <span class="sr-only"> repository for {project.data.title}</span>
                </a>
              )}
              {project.data.live && (
                <a href={project.data.live} class="link-quiet">
                  Live<ExternalArrow />
                  <span class="sr-only"> site for {project.data.title}</span>
                </a>
              )}
            </p>
          </div>

          {/* Thumbnail is a decorative duplicate of the case-study link: hidden from AT and tab order */}
          {
            project.data.cover && (
              <a
                href={`/projects/${project.id}/`}
                aria-hidden="true"
                tabindex="-1"
                class="transition-opacity hover:opacity-85"
              >
                <Image
                  src={project.data.cover}
                  alt=""
                  widths={[480, 960]}
                  sizes="(max-width: 768px) 100vw, (max-width: 1024px) 320px, 416px"
                  class="aspect-[4/3] w-full rounded-md border border-neutral-200 object-cover object-top"
                />
              </a>
            )
          }
        </article>
      ))
    }
  </div>
</section>
