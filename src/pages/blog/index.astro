---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base
  title="Blog · Samip Pokharel"
  description="Writing on software engineering, backend development, and building products, by Samip Pokharel."
>
  <section class="py-12 sm:py-16">
    <h1 class="text-3xl font-semibold tracking-tight text-neutral-900">Blog</h1>
    <p class="mt-4 max-w-prose leading-relaxed text-neutral-500">
      Occasional writing on engineering, careers, and building products.
    </p>

    <ul class="mt-12 space-y-10">
      {
        posts.map((post) => (
          <li>
            <article>
              <p class="font-mono text-xs text-neutral-400">
                <time datetime={post.data.date.toISOString().slice(0, 10)}>
                  {formatDate(post.data.date)}
                </time>
              </p>
              <h2 class="mt-2 text-xl font-medium">
                <a href={`/blog/${post.id}/`} class="text-neutral-900 transition-colors hover:text-(--color-accent)">
                  {post.data.title}
                </a>
              </h2>
              <p class="mt-2 max-w-prose text-sm leading-relaxed text-neutral-600">{post.data.description}</p>
            </article>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
