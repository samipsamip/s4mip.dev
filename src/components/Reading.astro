---
import { getCollection } from 'astro:content';
import BookMarkedIcon from '../assets/icons/book-marked.svg';
import ExternalArrow from './ExternalArrow.astro';

const links = (await getCollection('reading')).sort(
  (a, b) => b.data.added.valueOf() - a.data.added.valueOf()
);

const domain = (url: string) => new URL(url).hostname.replace(/^www\./, '');
---

<section id="reading" class="scroll-mt-8 border-t border-neutral-200 py-16" aria-labelledby="reading-heading">
  <h2 id="reading-heading" class="section-label flex items-center gap-2">
    <BookMarkedIcon width={14} height={14} aria-hidden="true" />
    Reading
  </h2>
  <p class="mt-4 max-w-xl text-sm text-neutral-500">
    Pieces from around the web worth more than a bookmark.
  </p>
  <ul class="mt-10 space-y-6">
    {
      links.map((link) => (
        <li>
          <article class="grid gap-1 sm:grid-cols-[8rem_1fr] sm:gap-6">
            <p class="meta-label leading-6">{domain(link.data.url)}</p>
            <div>
              <h3 class="font-medium">
                <a href={link.data.url} class="link-quiet" target="_blank" rel="noopener">
                  {link.data.title}<ExternalArrow />
                </a>
              </h3>
              {link.data.note && <p class="mt-1 text-sm text-neutral-500">{link.data.note}</p>}
            </div>
          </article>
        </li>
      ))
    }
  </ul>
</section>
